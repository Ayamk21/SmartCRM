# Supabase - pooler transaction-mode (utilise par l'app au quotidien)
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase - connexion directe (utilisee par Prisma pour les migrations)
DIRECT_URL="postgresql://postgres.xxxx:password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

PORT=3001
NODE_ENV=development

# Generer avec: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=changeme
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

FRONTEND_URL=http://localhost:3000
# Cle secrete de test (Dashboard Stripe > Developers > API keys)
STRIPE_SECRET_KEY=sk_test_xxx
# Genere par "stripe listen" en local, ou par le webhook configure sur le Dashboard
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Id du Price du produit "Pro" (Dashboard Stripe > Product catalog)
STRIPE_PRICE_ID_PRO=price_xxx
