generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  COLLABORATOR
}

enum PlanType {
  FREE
  PRO
}

enum TenantStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum ContactType {
  LEAD
  CLIENT
}

enum DealStatus {
  PROSPECT
  QUALIFICATION
  PROPOSITION
  GAGNE
  PERDU
}

enum ActivityType {
  CALL
  EMAIL
  NOTE
  STATUS_CHANGE
}

enum QuoteStatus {
  DRAFT
  VALIDATED
  CONVERTED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
}

model Tenant {
  id                   String       @id @default(cuid())
  name                 String
  logoUrl              String?
  currency             String       @default("EUR")
  siret                String?
  pdfTemplate          String?
  plan                 PlanType     @default(FREE)
  status               TenantStatus @default(PENDING)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  users      User[]
  contacts   Contact[]
  deals      Deal[]
  activities Activity[]
  quotes     Quote[]
  invoices   Invoice[]

  @@map("tenants")
}

model PlatformAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  @@map("platform_admins")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  role      Role     @default(COLLABORATOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sessions   Session[]
  activities Activity[]

  @@index([tenantId])
  @@map("users")
}

model Session {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Contact {
  id        String      @id @default(cuid())
  type      ContactType @default(LEAD)
  firstName String
  lastName  String?
  company   String?
  title     String?
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  deals      Deal[]
  activities Activity[]
  quotes     Quote[]
  invoices   Invoice[]

  @@index([tenantId])
  @@map("contacts")
}

model Deal {
  id        String     @id @default(cuid())
  title     String
  amount    Decimal    @db.Decimal(10, 2)
  status    DealStatus @default(PROSPECT)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  quotes Quote[]

  @@index([tenantId])
  @@index([contactId])
  @@map("deals")
}

model Activity {
  id        String       @id @default(cuid())
  type      ActivityType @default(NOTE)
  content   String
  createdAt DateTime     @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  createdByUserId String?
  createdByUser   User?   @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([contactId])
  @@map("activities")
}

model Quote {
  id         String      @id @default(cuid())
  number     String
  status     QuoteStatus @default(DRAFT)
  issueDate  DateTime    @default(now())
  validUntil DateTime?
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)

  lines   QuoteLine[]
  invoice Invoice?

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([contactId])
  @@map("quotes")
}

model QuoteLine {
  id          String  @id @default(cuid())
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_lines")
}

model Invoice {
  id        String        @id @default(cuid())
  number    String
  status    InvoiceStatus @default(DRAFT)
  issueDate DateTime      @default(now())
  dueDate   DateTime?
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  quoteId String? @unique
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  lines InvoiceLine[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([contactId])
  @@map("invoices")
}

model InvoiceLine {
  id          String  @id @default(cuid())
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_lines")
}
