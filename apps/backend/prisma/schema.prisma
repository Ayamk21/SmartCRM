generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  COLLABORATOR
}

enum PlanType {
  FREE
  PRO
}

enum TenantStatus {
  PENDING
  ACTIVE
  REJECTED
}

model Tenant {
  id          String       @id @default(cuid())
  name        String
  logoUrl     String?
  currency    String       @default("EUR")
  siret       String?
  pdfTemplate String?
  plan        PlanType     @default(FREE)
  status      TenantStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users User[]

  @@map("tenants")
}

model PlatformAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  @@map("platform_admins")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  role      Role     @default(COLLABORATOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sessions Session[]

  @@index([tenantId])
  @@map("users")
}

model Session {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}
